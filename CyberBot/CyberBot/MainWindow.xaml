<Window x:Class="CyberBot.MainWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Chatbot" Height="500" Width="400">

    <Grid Background="#1E1E2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="🤖 Cyber Bot"
                   Foreground="Cyan"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="10"/>

        <!-- Chat Display -->
        <ScrollViewer Grid.Row="1" Margin="10" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ChatPanel"/>
        </ScrollViewer>

        <!-- Input Area -->
        <DockPanel Grid.Row="2" Margin="10">
            <TextBox x:Name="UserInput" Width="280" Height="30" DockPanel.Dock="Left"/>
            <Button Content="Send" Width="80" Height="30" DockPanel.Dock="Right"
                    Click="SendButton_Click"/>
        </DockPanel>
    </Grid>
</Window>
